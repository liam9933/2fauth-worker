# 本地开发环境变量配置实例,请根据实际情况修改,获取方式请参照项目README.md

# [必填]系统安全参数
JWT_SECRET=YKPc4G****  # 越长越好,建议32位
ENCRYPTION_KEY=U6p5y95OKkK**** # 越长越好,建议32位

# [必填]Cloudflare D1 数据库参数
CLOUDFLARE_ACCOUNT_ID=fbce5f4***
CLOUDFLARE_API_TOKEN=yx5fupqCxK****

# [必填]Cloudflare 资源授权
CLOUDFLARE_D1_DATABASE_ID=9e591736-****
CLOUDFLARE_D1_DATABASE_NAME=2fauth-db-dev

# [必填]登录白名单，支持用户名和邮箱，多个用","分隔
OAUTH_ALLOWED_USERS=abc,abc@gmail.com

#必填：OAuth 身份信息 (按需选择对应的组合)，必选一种方式，建议github

# Github
OAUTH_GITHUB_CLIENT_ID=Ov23liIt****
OAUTH_GITHUB_CLIENT_SECRET=cd6de****
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8787/oauth/callback

